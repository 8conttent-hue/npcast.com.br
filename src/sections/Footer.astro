---
// Footer-F: Sitemap / Mega Footer - Design de alta densidade de informação
import siteConfig from '../data/siteConfig.json';
const { name, menu = [] } = siteConfig as any;
const year = new Date().getFullYear();

// Categorias extraídas do menu para o sitemap
const blogItem = menu.find((i: any) => i.label === 'Blog' || i.href === '/blog');
const sitemap = [
  { 
    title: 'Navegação', 
    links: menu.map((i: any) => ({ label: i.label, href: i.href })) 
  },
  { 
    title: 'Legal', 
    links: [
      { label: 'Privacidade', href: '/privacidade' },
      { label: 'Termos de Uso', href: '/termos' },
      { label: 'Contato', href: '/contato' }
    ] 
  }
];

if (blogItem?.children) {
  sitemap.push({
    title: 'Categorias',
    links: blogItem.children.map((c: any) => ({ label: c.label, href: c.href }))
  });
}
---
<footer class="bg-[#fcfcfd] border-t border-gray-100 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-12 mb-20 text-center md:text-left">
      
      <!-- Brand Column -->
      <div class="col-span-2">
        <h2 class="text-2xl font-black text-dark mb-6 tracking-tighter uppercase">{name}</h2>
        <p class="text-sm text-gray-400 font-medium leading-relaxed max-w-xs mb-8">
          Conteúdo especializado e informações atualizadas sobre {name}.
        </p>
      </div>

      <!-- Sitemap Columns -->
      {sitemap.map(section => (
        <div class="col-span-1">
          <h4 class="text-[10px] font-black uppercase tracking-[0.3em] text-dark mb-6">{section.title}</h4>
          <ul class="space-y-4">
             {section.links.map(link => (
               <li>
                 <a href={link.href} class="text-sm text-gray-400 font-medium hover:text-primary transition-colors">{link.label}</a>
               </li>
             ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="pt-10 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-6">
       <div class="flex items-center gap-6">
          <span class="text-[10px] font-black text-gray-300 uppercase tracking-widest">© {year} {name}</span>
          <div class="hidden md:block w-px h-4 bg-gray-100"></div>
          <span class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">Feito com Astro 5</span>
       </div>
       <div class="flex items-center gap-8">
          <a href="#" class="text-[10px] font-bold text-gray-300 hover:text-dark uppercase tracking-widest">Configurações</a>
          <a href="#" class="text-[10px] font-bold text-gray-300 hover:text-dark uppercase tracking-widest">Status</a>
       </div>
    </div>
  </div>
</footer>